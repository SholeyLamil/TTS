{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Telemetry": {
    "RetryCount": 5
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "transaction-events",
    "GroupId": "tts-influx-writer",
    "AutoOffsetReset": "Earliest"
  },
  "InfluxDb": {
    "Url": "http://localhost:8086",
    "Token": "",
    "Organisation": "",
    "Bucket": "",
    "Measurement": "transaction_events"
  }
}
