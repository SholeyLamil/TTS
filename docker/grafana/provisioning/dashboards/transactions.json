{
  "uid": "tts-transactions",
  "title": "Transaction Telemetry",
  "tags": ["tts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "INFLUX_BUCKET",
        "type": "constant",
        "label": "Bucket",
        "query": "transactions",
        "current": { "text": "transactions", "value": "transactions" },
        "hide": 2
      },
      {
        "name": "eventType",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${INFLUX_BUCKET}\", tag: \"eventType\")"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Event throughput (events/min)",
      "type": "timeseries",
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cpm" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"${INFLUX_BUCKET}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"transaction_events\" and r._field == \"count\")\n  |> aggregateWindow(every: 1m, fn: sum, createEmpty: false)\n  |> group(columns: [\"eventType\"])"
        }
      ]
    },
    {
      "id": 2,
      "title": "Events by type",
      "type": "piechart",
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "pie"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"${INFLUX_BUCKET}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"transaction_events\" and r._field == \"count\")\n  |> group(columns: [\"eventType\"])\n  |> sum()\n  |> keep(columns: [\"eventType\", \"_value\"])\n  |> rename(columns: {_value: \"events\"})\n  |> group()\n  |> pivot(rowKey: [], columnKey: [\"eventType\"], valueColumn: \"events\")"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total events",
      "type": "stat",
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"${INFLUX_BUCKET}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"transaction_events\" and r._field == \"count\")\n  |> group()\n  |> sum()"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed / reversed events",
      "type": "timeseries",
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "cpm" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"${INFLUX_BUCKET}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"transaction_events\" and r._field == \"count\")\n  |> filter(fn: (r) => r.eventType =~ /(?i)(fail|revers)/)\n  |> aggregateWindow(every: 1m, fn: sum, createEmpty: false)\n  |> group(columns: [\"eventType\"])"
        }
      ]
    }
  ]
}
