# Transaction Telemetry Service — configuration contract.
# Copy to .env and fill in real values. Consumed by docker-compose.yml.

# === Service settings (passed to the API container as Telemetry__* / InfluxDb__*) ===

# Shared secret required in the X-API-Key header on POST /api/events.
# REQUIRED — if empty the service fails closed and rejects every request.
TTS_API_KEY=change-me

# In-memory buffer size. When full, the newest event is dropped and logged. Default: 10000.
QUEUE_SIZE=10000

# Number of InfluxDB write attempts (exponential backoff) before an event is dropped. Default: 5.
RETRY_COUNT=5

# Minimum log level: Trace | Debug | Information | Warning | Error | Critical.
LOG_LEVEL=Information

# === InfluxDB connection ===
INFLUX_TOKEN=change-me-influx-token
INFLUX_ORG=tts
INFLUX_BUCKET=transactions

# === InfluxDB container bootstrap (not read by the API) ===
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me-admin-password

# === Grafana admin login (not read by the API) ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
